{
  "privileges": [],
  "dataRoles": [
    { "displayName": "Categoria", "name": "categoria", "kind": "Grouping" },
    { "displayName": "Valor", "name": "valor", "kind": "Measure" },
    { "displayName": "Legenda", "name": "legenda", "kind": "Grouping" },
    { "displayName": "Dica de ferramenta", "name": "tooltips", "kind": "Measure" }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "categoria": { "max": 1 }, "legenda": { "max": 1 } }
      ],
      "categorical": {
        "categories": {
          "select": [
            { "for": { "in": "categoria" } },
            { "for": { "in": "legenda" } }
          ],
          "dataReductionAlgorithm": { "top": { "count": 5000 } }
        },
        "values": {
          "select": [
            { "for": { "in": "valor" } },
            { "for": { "in": "tooltips" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "rosca": {
      "properties": {
        "raioExterno": { "type": { "numeric": true } },
        "larguraAnel": { "type": { "numeric": true } },
